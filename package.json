{
  "name": "mkimp",
  "version": "4.0.8",
  "description": "Write markdown like a programmer should be able to",
  "license": "MIT",
  "author": "FriquetLuca",
  "keywords": [
    "markdown",
    "md",
    "include",
    "import",
    "template",
    "programming",
    "modular",
    "inject",
    "documentation"
  ],
  "homepage": "https://github.com/FriquetLuca/mkimp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FriquetLuca/mkimp.git"
  },
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "scripts": {
    "build": "(rm -rf dist) && node build.mjs && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "lint": "eslint .",
    "prepare": "husky",
    "format": "prettier --write \"**/*.{js,ts,mjs,mts,json}\" --log-level silent"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.5.0",
    "esbuild": "0.27.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.40"
  },
  "lint-staged": {
    "**/*.{js,ts,mjs,mts,json}": [
      "prettier --write"
    ]
  }
}
